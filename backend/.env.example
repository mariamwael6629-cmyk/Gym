# Copy this file to .env and adjust values for your environment

# Database
DATABASE_URL=sqlite:///./gym.db

# JWT auth
SECRET_KEY=change-this-to-a-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Seed admin account (created on first startup if no admin exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!

# CORS - comma separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500
